# Mi Día — Variables de entorno para desarrollo local
# Copiar este archivo a .env.local y rellenar los valores
# NUNCA commitear .env.local con valores reales

# ─── PostgreSQL ────────────────────────────────────────────────────────────────
# Contraseña maestra de PostgreSQL (mínimo 32 caracteres)
POSTGRES_PASSWORD=your-super-secret-password-min-32-chars

# ─── JWT ───────────────────────────────────────────────────────────────────────
# Secret para firmar tokens JWT (mínimo 32 caracteres)
JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long

# Claves pre-generadas para desarrollo local
# Corresponden al JWT_SECRET de arriba — reemplazar en producción
ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRFA0NiJ7VhEkN4_tRCfxAEDdaA3S-gP_oPQFnegkNA
